# ── Database ──────────────────────────────────────────────────────────────────
# Local MongoDB:
#   MONGO_URI=mongodb://localhost:27017/ecommerce
# MongoDB Atlas (SRV URIs automatically enable a DNS workaround):
#   MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecommerce
MONGO_URI=mongodb://localhost:27017/ecommerce
DB_NAME=ecommerce

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use a long, random string. Never commit the real value.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
